GEMINI_API_KEY=ここにGemini_APIキーを入力
GEMINI_MODEL=gemini-3.5-flash
GEMINI_REVIEW_MODEL=gemini-3.1-flash-lite
GEMINI_JUDGE_MODEL=gemini-2.5-pro
GEMINI_EXTRACT_FALLBACK_MODEL=gemini-3.1-flash-lite
GEMINI_REQUEST_TIMEOUT_MS=60000
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_BASE_SECONDS=2

# 友人向け公開時のみ設定する。空欄の場合はパスワード画面を表示しない。
APP_ACCESS_PASSWORD=

# Streamlit Community Cloudでアカウントを永続保存する場合に設定する。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx

# 収集量と同時実行数。通常は変更不要。
PROGRESSIVE_SEARCH_WORKERS=6
PROGRESSIVE_FETCH_WORKERS=6
PROGRESSIVE_AI_WORKERS=2
PROGRESSIVE_MAX_PAGES_STANDARD=36
PROGRESSIVE_MAX_PAGES_COMPREHENSIVE=60
PROGRESSIVE_MAX_AI_PAGES=14
PROGRESSIVE_MAX_AI_PAGES_COMPREHENSIVE=24
PROGRESSIVE_EXCERPT_CHARS=6000
